<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp"
    android:background="@color/bg_light">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:text="Weekly Statistics"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/text_dark"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <com.example.aldiyarbaibogurov_test2.BarChartView
            android:id="@+id/barChart"
            android:layout_width="match_parent"
            android:layout_height="280dp"
            android:layout_marginTop="20dp"/>

        <!-- Detailed Stats Section -->
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:padding="15dp"
            android:background="@drawable/stats_border">

            <TextView
                android:id="@+id/tvTotalCalories"
                android:text="Total Calories Consumed: 0"
                android:textSize="18sp"
                android:textColor="@color/text_dark"
                android:layout_marginBottom="10dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/tvAvgCalories"
                android:text="Average Daily Calories: 0"
                android:textSize="18sp"
                android:textColor="@color/text_dark"
                android:layout_marginBottom="10dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/tvDaysTracked"
                android:text="Days Tracked: 0/7"
                android:textSize="18sp"
                android:textColor="@color/text_dark"
                android:layout_marginBottom="10dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/tvDaysGoalMet"
                android:text="Days Goal Met: 0"
                android:textSize="18sp"
                android:textColor="@color/text_dark"
                android:layout_marginBottom="10dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/tvDaysGoalNotMet"
                android:text="Days Goal Not Met: 0"
                android:textSize="18sp"
                android:textColor="@color/text_dark"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

        </LinearLayout>

        <Button
            android:id="@+id/btnBack"
            android:text="← Back"
            android:textAllCaps="false"
            android:backgroundTint="#DDDDDD"
            android:textColor="#000000"
            android:layout_marginTop="20dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>

</ScrollView>